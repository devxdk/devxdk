# Signed artifacts and their detached signatures must reach clients byte-for-byte
# identical to what was signed. Disable all git line-ending normalization on them
# (and CNAME) so signature verification can never break on a CRLF round-trip.
*.json    -text
*.minisig -text
CNAME     -text
# Trust material (public keys, the pinned-verifier hash, rotation records) must
# also round-trip verbatim so a CRLF can never break key parsing or verification.
keys/**   -text
scripts/devxdk_manifest/keys/** -text
